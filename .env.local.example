# Copy this file to .env.local and fill in real values.
# In production these are set in the Vercel dashboard for the
# creatixreach-marketing project (Settings -> Environment Variables).
#
# The marketing site has NO database, NO auth. Only the contact form
# needs configuration.

# Resend API key (same one the portal uses - copy from the portal's
# Vercel env vars). Without this, /contact returns a friendly error.
RESEND_API_KEY=

# Where to forward contact-form leads. Goes alongside info@creatixreach.io.
ADMIN_NOTIFICATION_EMAIL=elhadad.design@gmail.com
